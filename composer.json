{
    "name": "muazzambuilds/filament-ai-actions",
    "description": "OpenAI-powered Filament v5 actions for summarizing, rewriting, classifying, generating, and translating content.",
    "keywords": [
        "filament",
        "filament-plugin",
        "laravel",
        "openai",
        "ai",
        "actions"
    ],
    "homepage": "https://github.com/muazzambuilds/filament-ai-actions",
    "license": "MIT",
    "authors": [
        {
            "name": "Muazzam Builds",
            "email": "me@muazzamalikhan.com",
            "homepage": "https://github.com/muazzambuilds"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.0",
        "illuminate/contracts": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "MuazzamBuilds\\FilamentAiActions\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MuazzamBuilds\\FilamentAiActions\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "MuazzamBuilds\\FilamentAiActions\\FilamentAiActionsServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
